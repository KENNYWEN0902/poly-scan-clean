# =============================================================
# Polymarket Trading Bot - Environment Variables
# =============================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#   nano .env
# WARNING: NEVER commit .env to git!
# =============================================================

# REQUIRED: Ethereum private key (0x-prefixed)
POLY_PRIVATE_KEY=0x...

# Polymarket API credentials (optional - auto-derived from private key if not set)
# POLY_API_KEY=...
# POLY_API_SECRET=...
# POLY_PASSPHRASE=...

# Optional builder attribution code for CLOB V2
# POLY_BUILDER_CODE=0x...

# Signature type: 0=EOA, 1=Proxy, 2=Gnosis Safe
POLY_SIGNATURE_TYPE=2

# Required for Proxy/Gnosis Safe wallets
POLY_FUNDER_ADDRESS=0x...

# Optional: before 2026-04-28 11:00 UTC, point to the V2 pre-cutover host for dry runs
# After cutover, unset this or set it back to https://clob.polymarket.com
# POLY_CLOB_HOST=https://clob-v2.polymarket.com

# Optional: Custom Polygon RPC endpoint (recommended for reliability)
# POLY_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Trading parameters
# POLY_TAKE_PROFIT_PCT=0.50
# POLY_STOP_LOSS_PCT=0.20
# POLY_TRADE_AMOUNT=10        # Fixed USD amount per trade (overrides Kelly sizing)
# POLY_BUY_SLIPPAGE=0.05      # Custom buy slippage (0.01-0.50)

# Dashboard API server port (optional, default: 9876)
# API_PORT=9876
