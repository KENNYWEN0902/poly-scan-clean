# Copy this file to .env on the Ubuntu server.
# Recommended: do not store your real private key in this local project folder.
# Replace POLY_PRIVATE_KEY only after uploading to the server.

POLY_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
POLY_SIGNATURE_TYPE=2
POLY_FUNDER_ADDRESS=0xREPLACE_WITH_YOUR_PROFILE_ADDRESS

# Optional: before 2026-04-28 11:00 UTC, point the bot at the V2 pre-cutover host
# POLY_CLOB_HOST=https://clob-v2.polymarket.com
# Optional: builder attribution code for CLOB V2
# POLY_BUILDER_CODE=0x...

# Optional but recommended trading settings for your first small test
POLY_TAKE_PROFIT_PCT=0.50
POLY_STOP_LOSS_PCT=0.30
POLY_TRADE_AMOUNT=5
# POLY_BUY_SLIPPAGE=0.05

# Optional dashboard API port
API_PORT=9876

# Optional custom Polygon RPC
# POLY_RPC_URL=https://your-polygon-rpc
